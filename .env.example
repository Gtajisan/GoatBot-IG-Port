# Instagram Credentials
IG_USERNAME=your_username
IG_PASSWORD=your_password

# 2FA Code (Optional - for non-interactive login)
# IG_2FA_CODE=123456

# Checkpoint Code (Optional)
# IG_CHECKPOINT_CODE=123456

# Bot Admin (Optional - overrides config.json if implemented)
# ADMIN_BOT=["123456789"]

# Prefix (Optional)
# PREFIX=/
